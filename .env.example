# Порт HTTP-сервера (статика + прокси /api/webhook)
PORT=8765

# Полный путь к node, если нет в PATH (часто на VPS после установки из пакета)
# NODE_BIN=/usr/bin/node

# URL вебхука n8n / backend (и для прокси, и для /api/client-config.js)
WEBHOOK_UPSTREAM=https://senoth.cashercollection.com/webhook/bddcd127-c647-4823-9ad9-8a9dd4688621

# production | development
NODE_ENV=production

# При ./deploy.sh без node: на Ubuntu/Debian автоматически ставить Node (NodeSource).
# AUTO_INSTALL_NODE=0 — не ставить, только сообщение об ошибке

# --- Опционально: выкладка ./deploy.sh push ---
# DEPLOY_HOST=example.com
# DEPLOY_USER=ubuntu
# DEPLOY_PATH=/opt/ai-agents
# Файл .env на сервер не копируется — создай его там вручную один раз.
# DEPLOY_REMOTE_CMD='sudo systemctl restart ai-agents && sudo systemctl is-active ai-agents'
